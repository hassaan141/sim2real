# Conservative CloudXR defaults for Meta Quest 2 / WebXR testing.
#
# Resolution and refresh rate are controlled in the CloudXR.js Debug Settings
# page on the headset. Start with Quest 2 defaults plus 1536x1344 per eye at
# 72 Hz, then raise it only after the stream is stable.
NV_DEVICE_PROFILE=auto-webrtc
# Keep this disabled for built-in headset optical hand tracking.
# Enabling push devices is for external trackers/gloves, not Quest hand cameras.
NV_CXR_ENABLE_PUSH_DEVICES=false
NV_CXR_ENABLE_TENSOR_DATA=true
NV_CXR_FILE_LOGGING=true
NV_PACER_FIXED_TIME_STEP_MS=14
